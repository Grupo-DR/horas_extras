rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Fetch the user's profile
    function getUserProfile() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      let profile = getUserProfile();
      return profile != null && profile.isSuperAdmin == true;
    }

    // Check if user is IAM Admin (or Super Admin)
    function isIAMAdmin() {
       let profile = getUserProfile();
       return (profile != null && profile.isSuperAdmin == true) || 
              (profile != null && profile.modules.commercial.role == 'IAM_ADMIN'); 
    }

    // --- User Profiles ---
    
    match /user_profiles/{userId} {
      // Read: Own profile OR Admin
      allow read: if isAuthenticated() && (request.auth.uid == userId || isIAMAdmin());
      
      // Write: Admin Only
      allow write: if isAuthenticated() && isIAMAdmin();
    }

    // --- User Directory (Public Catalog for CRM) ---
    match /user_directory/{userId} {
      // Read: Any authenticated user can read the company directory
      allow read: if isAuthenticated();
      // Write: Only Cloud Functions (Admin SDK) can write here
      allow write: if false;
    }

    // --- Audit Logs ---
    match /audit_logs/{logId} {
      // Only IAM Admins can read or write audit logs directly from client
      // Note: Cloud Functions bypass these rules entirely.
      allow read, write: if isAuthenticated() && isIAMAdmin();
    }

    // --- Legacy / Other Collections ---

    // Existing 'users' collection used by AuthContext legacy logic
    match /users/{userId} {
      // Restrict so users can only touch their own legacy record, or Admin can touch everything
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isIAMAdmin());
    }
    
    // Placeholder for future HC collections if migrated to Firestore
    match /hc_planning_records/{recordId} {
       allow read: if isAuthenticated(); // TODO: Add granular scope checks when migrated
       allow write: if isAuthenticated(); // TODO: Add role checks when migrated
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
